# Uygulama Ortamı (development / production)
# ONEMLI: Prod'da 'production' yapın → cookie Secure=True olur (HTTPS zorunlu)
# Local HTTP dev'de 'development' bırakın → cookie Secure=False (login çalışır)
ENV=development

# JWT Security
# Prod ortamında mutlaka rastgele güçlü bir şifre belirleyin:
# Örn: openssl rand -hex 32
JWT_SECRET_KEY=kendi_guclu_gizli_anahtarinizi_buraya_yazin

# Veritabanı Bağlantı Bilgileri
DB_USER=postgres
DB_PASSWORD=BURAYA_EN_AZ_16_KARAKTER_GUCLU_SIFRE_YAZIN
DB_NAME=borsa_app
DB_HOST=db
DB_PORT=5432

# FastAPI DB URL (Genelde yukarıdaki DB_* değişkenlerinden Docker-Compose üzerinden oluşturulur)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Yapay Zeka - Gemini API (Google AI Studio üzerinden alınır)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot (Opsiyonel)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Frontend URL Config
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS - Prod ortamında virgul ile ayrılmış domain listesi
# Ornek: ALLOWED_ORIGINS=https://borsaterminal.com,https://www.borsaterminal.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
